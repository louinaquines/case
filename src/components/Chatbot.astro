---
/* Chatbot component - Updated styling to match user's example */
---

<div class="cb-wrapper">
  <button id="cb-toggle" class="cb-toggle" aria-label="Open chat">
    <svg class="cb-toggle-icon" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
    </svg>
    <span class="cb-toggle-text">Chat with Loui</span>
  </button>

  <div id="cb-window" class="cb-window" aria-hidden="true">
    <div class="cb-header">
      <div class="cb-header-avatar">
        L
        <span class="cb-online-dot"></span>
      </div>
      <div class="cb-header-meta">
        <div class="cb-header-name">Loui's Assistant</div>
        <div class="cb-header-status" id="cb-status">online</div>
      </div>
      <button id="cb-close" class="cb-header-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div id="cb-messages" class="cb-messages">
      <div class="cb-date-chip">Today</div>
      <div class="cb-row cb-row-in">
        <div class="cb-bub cb-bub-in">
          Hi! 👋 I'm Loui's AI assistant. Ask me anything about his skills, projects, or experience!
          <span class="cb-time">now</span>
        </div>
      </div>
    </div>

    <div id="cb-typing" class="cb-typing-row" style="display:none">
      <div class="cb-typing-pill">
        <span></span><span></span><span></span>
      </div>
    </div>

    <div class="cb-input-bar">
      <input id="cb-input" class="cb-input" type="text" placeholder="Message..." autocomplete="off" />
      <button id="cb-send" class="cb-send" aria-label="Send">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .cb-wrapper {
    position: fixed !important;
    bottom: 1rem !important;
    right: 1rem !important;
    z-index: 9999 !important;
    font-family: inherit;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  /* ── Toggle Button - Matching user's example ── */
  .cb-wrapper .cb-toggle {
    position: relative;
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    background: var(--color-accent, #3b82f6);
    color: #ffffff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    transition: background 0.2s ease, color 0.2s ease;
    margin: 0;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }

  :global([data-theme="dark"]) .cb-wrapper .cb-toggle {
    background: #ffffff;
    color: #000000;
  }

  .cb-wrapper .cb-toggle:hover {
    background: rgba(59, 130, 246, 0.9);
  }

  :global([data-theme="dark"]) .cb-wrapper .cb-toggle:hover {
    background: rgba(255, 255, 255, 0.9);
  }

  .cb-wrapper .cb-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .cb-wrapper .cb-toggle-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .cb-wrapper .cb-toggle-text {
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Toggle open state */
  .cb-wrapper.cb-open .cb-toggle-icon {
    display: none;
  }

  .cb-wrapper.cb-open .cb-toggle-text {
    display: none;
  }

  /* ── Window ── */
  .cb-wrapper .cb-window {
    position: absolute;
    bottom: 100%;
    right: 0;
    width: 380px;
    max-height: 500px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    margin-bottom: 0.75rem;
  }

  .cb-wrapper.cb-open .cb-window {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* ── Header ── */
  .cb-wrapper .cb-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .cb-wrapper .cb-header-avatar {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.875rem;
    position: relative;
  }

  .cb-wrapper .cb-online-dot {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 0.625rem;
    height: 0.625rem;
    background: #22c55e;
    border-radius: 50%;
    border: 2px solid var(--color-bg);
  }

  .cb-wrapper .cb-header-meta {
    flex: 1;
    min-width: 0;
  }

  .cb-wrapper .cb-header-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .cb-wrapper .cb-header-status {
    font-size: 0.75rem;
    color: #22c55e;
  }

  .cb-wrapper .cb-header-close {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.25rem;
    transition: background 0.15s;
  }

  .cb-wrapper .cb-header-close:hover {
    background: var(--color-bg-elevated);
    color: var(--color-text);
  }

  /* ── Messages ── */
  .cb-wrapper .cb-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 200px;
    max-height: 320px;
  }

  .cb-wrapper .cb-date-chip {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-bottom: 0.25rem;
  }

  .cb-wrapper .cb-row {
    display: flex;
    flex-direction: column;
  }

  .cb-wrapper .cb-row-in {
    align-items: flex-start;
  }

  .cb-wrapper .cb-row-out {
    align-items: flex-end;
  }

  .cb-wrapper .cb-bub {
    max-width: 85%;
    padding: 0.625rem 0.875rem;
    border-radius: 1rem;
    font-size: 0.875rem;
    line-height: 1.5;
    position: relative;
  }

  .cb-wrapper .cb-bub-in {
    background: var(--color-bg);
    color: var(--color-text);
    border-bottom-left-radius: 0.25rem;
  }

  .cb-wrapper .cb-bub-out {
    background: var(--color-accent);
    color: #ffffff;
    border-bottom-right-radius: 0.25rem;
  }

  .cb-wrapper .cb-time {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    margin-left: 0.5rem;
    vertical-align: middle;
  }

  /* ── Typing ── */
  .cb-wrapper .cb-typing-row {
    padding: 0 1rem 0.5rem;
    display: flex;
    justify-content: flex-start;
  }

  .cb-wrapper .cb-typing-pill {
    background: var(--color-bg);
    border-radius: 1rem;
    padding: 0.625rem 0.875rem;
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .cb-wrapper .cb-typing-pill span {
    width: 0.375rem;
    height: 0.375rem;
    background: var(--color-text-muted);
    border-radius: 50%;
    animation: cb-typing-bounce 1.4s infinite ease-in-out;
  }

  .cb-wrapper .cb-typing-pill span:nth-child(1) { animation-delay: 0s; }
  .cb-wrapper .cb-typing-pill span:nth-child(2) { animation-delay: 0.2s; }
  .cb-wrapper .cb-typing-pill span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes cb-typing-bounce {
    0%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-0.375rem); }
  }

  /* ── Input Bar ── */
  .cb-wrapper .cb-input-bar {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .cb-wrapper .cb-input {
    flex: 1;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s;
  }

  .cb-wrapper .cb-input:focus {
    border-color: var(--color-accent);
  }

  .cb-wrapper .cb-input::placeholder {
    color: var(--color-text-muted);
  }

  .cb-wrapper .cb-send {
    background: var(--color-accent);
    border: none;
    border-radius: 50%;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #fff;
    transition: background 0.15s, transform 0.1s;
  }

  .cb-wrapper .cb-send:hover {
    background: var(--color-accent-hover);
  }

  .cb-wrapper .cb-send:active {
    transform: scale(0.95);
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .cb-wrapper {
      bottom: 1rem !important;
      right: 1rem !important;
    }
    .cb-wrapper .cb-toggle {
      padding: 0.6rem 1rem;
    }
    .cb-wrapper .cb-toggle-text {
      display: none;
    }
    .cb-wrapper .cb-window {
      width: calc(100vw - 2rem);
      right: -0.75rem;
      height: calc(100vh - 180px);
      max-height: 470px;
      bottom: 60px;
    }
  }

  @media (min-width: 481px) and (max-width: 768px) {
    .cb-wrapper {
      bottom: 1.25rem !important;
      right: 1.25rem !important;
    }
    .cb-wrapper .cb-toggle {
      padding: 0.6rem 1rem;
    }
    .cb-wrapper .cb-toggle-text {
      display: none;
    }
    .cb-wrapper .cb-window {
      width: 350px;
      height: calc(100vh - 200px);
      max-height: 500px;
      bottom: 60px;
      right: 0;
    }
  }

  @media (max-width: 360px) {
    .cb-wrapper {
      bottom: 0.75rem !important;
      right: 0.75rem !important;
    }
    .cb-wrapper .cb-window {
      width: calc(100vw - 1.5rem);
      right: -0.5rem;
    }
  }
</style>

<script is:inline>
  (function() {
    const toggleBtn = document.getElementById('cb-toggle');
    const cbWindow  = document.getElementById('cb-window');
    const closeBtn  = document.getElementById('cb-close');
    const sendBtn   = document.getElementById('cb-send');
    const inputEl   = document.getElementById('cb-input');
    const msgsEl    = document.getElementById('cb-messages');
    const typingEl  = document.getElementById('cb-typing');
    const cbWrapper = document.querySelector('.cb-wrapper');

    if (!toggleBtn || !cbWindow) return;

    // Toggle window
    toggleBtn.addEventListener('click', function() {
      cbWrapper.classList.toggle('cb-open');
      if (cbWrapper.classList.contains('cb-open')) {
        inputEl?.focus();
      }
    });

    // Close window
    closeBtn?.addEventListener('click', function() {
      cbWrapper.classList.remove('cb-open');
    });

    // Close when clicking outside
    document.addEventListener('click', function(e) {
      if (!cbWrapper.contains(e.target)) {
        cbWrapper.classList.remove('cb-open');
      }
    });

    // Send message
    function sendMessage() {
      const msg = inputEl?.value.trim();
      if (!msg) return;

      // Add user message
      const userRow = document.createElement('div');
      userRow.className = 'cb-row cb-row-out';
      userRow.innerHTML = `<div class="cb-bub cb-bub-out">${escapeHtml(msg)}<span class="cb-time">now</span></div>`;
      msgsEl?.appendChild(userRow);
      msgsEl.scrollTop = msgsEl.scrollHeight;
      inputEl.value = '';

      // Show typing indicator
      typingEl.style.display = 'flex';
      msgsEl.scrollTop = msgsEl.scrollHeight;

      // Simulate response
      setTimeout(async () => {
        typingEl.style.display = 'none';
        
        try {
          const res = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: msg })
          });
          const data = await res.json();
          const reply = data.reply || "Thanks for your message! I'll get back to you soon.";
          
          const botRow = document.createElement('div');
          botRow.className = 'cb-row cb-row-in';
          botRow.innerHTML = `<div class="cb-bub cb-bub-in">${escapeHtml(reply)}<span class="cb-time">now</span></div>`;
          msgsEl?.appendChild(botRow);
        } catch (err) {
          const errorRow = document.createElement('div');
          errorRow.className = 'cb-row cb-row-in';
          errorRow.innerHTML = `<div class="cb-bub cb-bub-in">Sorry, something went wrong. Please try again.<span class="cb-time">now</span></div>`;
          msgsEl?.appendChild(errorRow);
        }
        
        msgsEl.scrollTop = msgsEl.scrollHeight;
      }, 1000);
    }

    sendBtn?.addEventListener('click', sendMessage);
    inputEl?.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') sendMessage();
    });

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }
  })();
</script>
